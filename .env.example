# ─── Backend ────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values. Never commit .env

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/trainer_app

# JWT secret — use a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret

# JWT expiry
JWT_EXPIRES_IN=7d

# Server port
PORT=3001

# CORS origin — your frontend URL
CORS_ORIGIN=http://localhost:5173

# ─── Cloudinary (exercise media uploads) ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
# Vite exposes env vars prefixed with VITE_ to the browser
VITE_API_URL=http://localhost:3001
