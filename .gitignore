# Private — not for version control
design/brand/
docs/product-development/
docs/user-tasks/

# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
dev-dist/
build/

# Environment files — never commit secrets
.env
.env.local
.env.*.local

# Drizzle generated files (keep migrations, ignore snapshots)
drizzle/meta/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# PWA generated files
sw.js
workbox-*.js

# Errors for claude to view
errors/

# Local assets — not tracked in version control
app-snapshots/
images/
# local DB dumps — never commit (contains PII)
db-backups/

# outbox to the workbench (Mode A) — local handoff, read via mount
forModeA/
