hoist-pattern[]=zod
hoist-pattern[]=drizzle-orm
hoist-pattern[]=pg

# Always install devDependencies regardless of NODE_ENV.
# Railway sets NODE_ENV=production at the Docker build level, which pnpm
# interprets as --prod (skip devDeps). This overrides that behaviour so
# tsc and other build tools are always available during the build phase.
production=false
