# ------------------------------------------------------------
# Backend environment variables
# Copy to .env and fill in real values before running.
# NEVER commit .env to source control.
#
# TO GET RUNNING:
#   1. cp apps/backend/.env.example apps/backend/.env
#   2. Fill in DATABASE_URL, JWT_SECRET, COOKIE_SECRET below
#   3. From the monorepo root:
#        pnpm install
#        pnpm approve-builds   # approve argon2 and esbuild native builds
#        pnpm install          # re-run after approving
#        cd apps/backend
#        pnpm db:push          # apply schema to database (dev)
#        cd ../..
#        pnpm dev
#
# NOTE: Use pnpm db:push during development.
#       Use pnpm db:generate && pnpm db:migrate for production deployments
#       or when setting up a fresh database from scratch.
# ------------------------------------------------------------

# ── Database ──────────────────────────────────────────────────────────────────
# Railway injects this automatically in production.
# For local dev: create a PostgreSQL DB and paste the connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/trainer_app

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# Frontend origin — update for production (your Vercel URL)
CORS_ORIGIN=http://localhost:5173

# ── JWT ───────────────────────────────────────────────────────────────────────
# JWT_SECRET: signs access tokens. Use a long random string.
#   Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-byte-random-hex-string

# Access token lifetime (15 minutes recommended)
JWT_ACCESS_TTL=15m

# Refresh token lifetime in milliseconds (7 days = 604800000)
JWT_REFRESH_TTL_MS=604800000

# ── Cookies ───────────────────────────────────────────────────────────────────
# COOKIE_SECRET: signs the httpOnly refresh token cookie.
# Must be different from JWT_SECRET.
#   Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=replace-with-32-byte-random-hex-string

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Required for exercise media uploads. Free tier is fine for development.
# Create an account at https://cloudinary.com/ → Dashboard → Settings → Access Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
