# ── Frontend environment variables ────────────────────────────────────────────
# Copy to .env.local for local dev (already proxied via Vite — usually not needed)
# Set in Vercel dashboard for production deployment

# Backend API URL
# In development: handled by Vite's proxy (vite.config.ts) — leave unset.
# In production (Vercel): DO NOT set this. Leave unset so it defaults to '/api/v1',
# which routes through the Vercel proxy rewrite → Railway. Setting this to the
# Railway URL directly bypasses the proxy and breaks refresh token cookies.
# VITE_API_URL=

# ── Vercel dashboard env vars (not in this file — set in Vercel UI) ───────────
# RAILWAY_BACKEND_URL   hostname only, no https://  e.g. my-app.up.railway.app
#                       Used by vercel.json rewrite to proxy /api/* to Railway.
