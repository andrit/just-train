# ── Frontend environment variables ────────────────────────────────────────────
# Copy to .env.local for local dev (already proxied via Vite — usually not needed)
# Set in Vercel dashboard for production deployment

# Backend API URL — set to your Railway backend URL in production
# In development this is handled by Vite's proxy (vite.config.ts)
# so VITE_API_URL is not needed locally.
VITE_API_URL=https://your-backend.railway.app/api/v1
